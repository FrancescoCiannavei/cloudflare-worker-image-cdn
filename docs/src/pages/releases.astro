---
import Layout from "../layouts/Layout.astro";
import { Marked } from "marked";
import { fetchReleases, deployUrl, REPO_URL } from "../lib/releases";

const marked = new Marked({ gfm: true, breaks: false });

marked.use({
	renderer: {
		link({ href, title, tokens }) {
			const text = this.parser.parseInline(tokens);
			const titleAttr = title ? ` title="${title}"` : "";
			return `<a href="${href}"${titleAttr} target="_blank" rel="noopener">${text}</a>`;
		},
	},
});

const MENTION_RE = /(^|[^\w`/])@([a-zA-Z0-9](?:[a-zA-Z0-9-]{0,38}[a-zA-Z0-9])?)\b/g;
function linkifyMentions(html: string): string {
	return html.replace(
		/(<code[^>]*>[\s\S]*?<\/code>|<a[\s\S]*?<\/a>)|([^<]+)/g,
		(_m, skip, text) => {
			if (skip) return skip;
			return text.replace(
				MENTION_RE,
				(_: string, pre: string, user: string) =>
					`${pre}<a href="https://github.com/${user}" target="_blank" rel="noopener">@${user}</a>`,
			);
		},
	);
}

const result = await fetchReleases();
const releases = result.ok ? result.releases : [];
const fetchError = result.ok ? null : result.error;

const dateFormatter = new Intl.DateTimeFormat("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});
---

<Layout title="Releases - Worker Image CDN" description="All published releases of Worker Image CDN, including changelogs and one-click Cloudflare deploy links.">
	<h1>Releases</h1>
	<p>All published releases from the <a href={`${REPO_URL}/releases`} target="_blank" rel="noopener">GitHub repository</a>.</p>

	{fetchError && (
		<div class="error">
			Could not load releases: {fetchError}
		</div>
	)}

	{!fetchError && releases.length === 0 && (
		<p class="empty">No releases published yet.</p>
	)}

	{releases.length > 0 && (
		<ul class="releases">
			{releases.map((release) => (
				<li class="release">
					<div class="release-header">
						<a href={release.html_url} target="_blank" rel="noopener" class="release-title">
							{release.name || release.tag_name}
						</a>
						{release.prerelease && <span class="badge">pre-release</span>}
					</div>
					<div class="release-meta">
						<code>{release.tag_name}</code>
						{release.published_at && (
							<span>
								{dateFormatter.format(new Date(release.published_at))}
							</span>
						)}
					</div>
					{release.body && (
						<div class="release-body" set:html={linkifyMentions(marked.parse(release.body) as string)} />
					)}
					<a
						class="deploy-button"
						href={deployUrl(release.tag_name)}
						target="_blank"
						rel="noopener"
					>
						Deploy {release.tag_name} to Cloudflare Workers
					</a>
				</li>
			))}
		</ul>
	)}
</Layout>

<style lang="scss">
	@use "../style/vars" as *;

	.releases {
		display: flex;
		flex-direction: column;
		gap: 24px;
		list-style: none;
		padding: 0;
		margin-top: 24px;
	}

	.release {
		border: 1px solid $borderCol;
		border-radius: 8px;
		padding: 20px 24px;
		background: rgba(#fff, 0.02);
	}

	.release-header {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 6px;
	}

	.release-title {
		font-size: 1.25rem;
		font-weight: 600;
		color: #fff;
		text-decoration: none;

		&:hover {
			color: $mainCol;
		}
	}

	.badge {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 2px 8px;
		border-radius: 4px;
		background: rgba($mainCol, 0.15);
		color: $mainCol;
	}

	.release-meta {
		display: flex;
		gap: 16px;
		font-size: 0.8rem;
		color: $textSecondary;
		margin-bottom: 12px;

		code {
			font-family: inherit;
		}
	}

	.deploy-button {
		display: inline-block;
		margin-top: 16px;
		padding: 8px 16px;
		border-radius: 6px;
		background: $mainCol;
		color: #000;
		font-size: 0.8rem;
		font-weight: 600;
		text-decoration: none;
		transition: opacity 0.15s;

		&:hover {
			opacity: 0.85;
		}
	}

	.release-body {
		padding: 12px 16px;
		background: rgba(#000, 0.25);
		border-radius: 6px;
		font-size: 0.85rem;
		color: $textSecondary;
		line-height: 1.5;

		:global(p) {
			margin: 0 0 0.75em;
		}

		:global(p:last-child),
		:global(ul:last-child),
		:global(ol:last-child) {
			margin-bottom: 0;
		}

		:global(h1),
		:global(h2),
		:global(h3),
		:global(h4) {
			margin: 1em 0 0.5em;
			color: $textPrimary;
			font-size: 1rem;
		}

		:global(ul),
		:global(ol) {
			margin: 0 0 0.75em;
			padding-left: 1.25em;
		}

		:global(code) {
			padding: 1px 5px;
			border-radius: 3px;
			background: rgba(#fff, 0.06);
			font-size: 0.85em;
		}

		:global(pre) {
			margin: 0 0 0.75em;
			padding: 10px 12px;
			border-radius: 4px;
			background: rgba(#000, 0.35);
			overflow-x: auto;

			code {
				padding: 0;
				background: transparent;
			}
		}

		:global(a) {
			color: $mainCol;
		}
	}

	.error {
		padding: 12px 16px;
		border-radius: 6px;
		background: rgba(red, 0.1);
		border: 1px solid rgba(red, 0.3);
		color: #ffb4b4;
		font-size: 0.875rem;
	}

	.empty {
		color: $textSecondary;
		font-style: italic;
	}
</style>
