---
const currentPath = Astro.url.pathname;
---

<header class="navbar">
	<div class="left">
		<button class="menu-toggle" aria-label="Toggle navigation" aria-controls="sidebar" aria-expanded="false">
			<span class="bar"></span>
			<span class="bar"></span>
			<span class="bar"></span>
		</button>
		<a href="/" class="logo">
			<span class="logo-icon">CDN</span>
			<span class="logo-text">Worker Image CDN</span>
		</a>
	</div>
	<nav>
		<a href="https://github.com/francescociannavei/cloudflare-worker-image-cdn" target="_blank" rel="noopener">
			GitHub
		</a>
	</nav>
</header>

<style lang="scss">
	@use "../style/vars" as *;

	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		height: $navHeight;
		background: rgba($bgDark, 0.8);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid $borderCol;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 $siteSpacing;
		z-index: 100;
	}

	.left {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.menu-toggle {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 4px;
		width: 36px;
		height: 36px;
		padding: 0;
		border: 1px solid $borderCol;
		border-radius: 6px;
		background: transparent;
		cursor: pointer;

		.bar {
			display: block;
			width: 18px;
			height: 2px;
			margin: 0 auto;
			background: $textPrimary;
			transition: transform 0.2s, opacity 0.2s;
		}
	}

	:global(body.sidebar-open) .menu-toggle {
		.bar:nth-child(1) {
			transform: translateY(6px) rotate(45deg);
		}
		.bar:nth-child(2) {
			opacity: 0;
		}
		.bar:nth-child(3) {
			transform: translateY(-6px) rotate(-45deg);
		}
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
	}

	.logo-icon {
		background: $mainCol;
		color: #fff;
		font-weight: 700;
		font-size: 0.75rem;
		padding: 4px 8px;
		border-radius: 6px;
		letter-spacing: 0.05em;
	}

	.logo-text {
		color: #fff;
		font-weight: 600;
		font-size: 1rem;
	}

	nav a {
		color: $textSecondary;
		font-size: 0.875rem;
		text-decoration: none;
		transition: color 0.15s;

		&:hover {
			color: #fff;
		}
	}

	@media (max-width: 768px) {
		.menu-toggle {
			display: flex;
		}

		.logo-text {
			display: none;
		}
	}
</style>
