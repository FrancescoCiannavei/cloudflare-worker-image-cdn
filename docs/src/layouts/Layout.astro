---
import "../style/style.scss";
import Navbar from "../components/Navbar.astro";
import Sidebar from "../components/Sidebar.astro";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Worker Image CDN",
	description = "Fast, self-hosted image CDN running on Cloudflare Workers with on-the-fly AVIF/WebP conversion, resizing, quality control, and caching.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
	</head>
	<body>
		<Navbar />
		<Sidebar />
		<main>
			<slot />
			<footer>
				Built by <a href="https://github.com/FrancescoCiannavei" target="_blank" rel="noopener">Francesco Ciannavei</a>
			</footer>
		</main>
	</body>
</html>

<style lang="scss">
	@use "../style/vars" as *;

	main {
		margin-left: $sidebarWidth;
		margin-top: $navHeight;
		padding: 40px 48px;
		max-width: 800px;
	}

	footer {
		margin-top: 60px;
		padding-top: 20px;
		border-top: 1px solid $borderCol;
		font-size: 0.8rem;
		color: $textSecondary;

		a {
			color: $textSecondary;
			text-decoration: underline;

			&:hover {
				color: #fff;
			}
		}
	}
</style>
