---
import "../style/style.scss";
import Navbar from "../components/Navbar.astro";
import Sidebar from "../components/Sidebar.astro";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Worker Image CDN",
	description = "Fast, self-hosted image CDN running on Cloudflare Workers with on-the-fly AVIF/WebP conversion, resizing, quality control, and caching.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
	</head>
	<body>
		<Navbar />
		<Sidebar />
		<div class="sidebar-overlay" data-sidebar-overlay></div>
		<main>
			<slot />
			<footer>
				Built by <a href="https://github.com/FrancescoCiannavei" target="_blank" rel="noopener">Francesco Ciannavei</a>
			</footer>
		</main>
	</body>
</html>

<script>
	const toggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
	const overlay = document.querySelector<HTMLDivElement>("[data-sidebar-overlay]");
	const sidebar = document.getElementById("sidebar");

	function close() {
		document.body.classList.remove("sidebar-open");
		toggle?.setAttribute("aria-expanded", "false");
	}

	function open() {
		document.body.classList.add("sidebar-open");
		toggle?.setAttribute("aria-expanded", "true");
	}

	toggle?.addEventListener("click", () => {
		if (document.body.classList.contains("sidebar-open")) close();
		else open();
	});

	overlay?.addEventListener("click", close);

	sidebar?.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));

	window.addEventListener("resize", () => {
		if (window.innerWidth > 768) close();
	});
</script>

<style lang="scss">
	@use "../style/vars" as *;

	main {
		margin-left: $sidebarWidth;
		margin-top: $navHeight;
		padding: 40px 48px;
		max-width: 800px;
	}

	.sidebar-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.5);
		z-index: 80;
	}

	@media (max-width: 768px) {
		main {
			margin-left: 0;
			padding: 24px 20px;
		}

		:global(body.sidebar-open) .sidebar-overlay {
			display: block;
		}
	}

	footer {
		margin-top: 60px;
		padding-top: 20px;
		border-top: 1px solid $borderCol;
		font-size: 0.8rem;
		color: $textSecondary;

		a {
			color: $textSecondary;
			text-decoration: underline;

			&:hover {
				color: #fff;
			}
		}
	}
</style>
